PORT=8787
# 监听地址，容器/公网请保持 0.0.0.0（默认已是 0.0.0.0）
# HOST=0.0.0.0
OPENAI_API_KEY=sk-your-key
OPENAI_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4.1-mini
# 逗号分隔的前端可选模型列表；可随时增删（首项建议放常用模型）
# MODEL_OPTIONS=gpt-4.1-mini,gpt-4.1,gpt-4o-mini,gpt-4o

# RAG：向量模型与检索参数（需与 OpenAI 兼容的 Embeddings 接口）
# EMBEDDING_MODEL=text-embedding-3-small
# RAG_TOP_K=6
# RAG_MIN_SIMILARITY=0.22
# CHUNK_TARGET_CHARS=2000
# CHUNK_MIN_CHARS=450
# CHUNK_OVERLAP_RATIO=0.15
# MAX_CHUNKS=280
# PRD_SUMMARY_MAX_CHARS=24000
# EMBED_BATCH_SIZE=64
# RATE_LIMIT_DOCUMENT_QUERY_MAX=60

# 公网部署务必开启：置于 Nginx/Caddy/平台负载均衡之后时，速率限制才能按真实访客 IP 统计
# TRUST_PROXY=1

# 生产环境建议（云平台有的会自动注入）
# NODE_ENV=production

# 默认为精简健康检查；开启后 /api/health 会返回 baseUrl、模型名等调试信息（请勿对公网长期开启）
# HEALTH_VERBOSE=1

# 上传与 JSON 体积上限（PDF 默认 32MB，请求体默认 2MB）
# PDF_MAX_UPLOAD_MB=32
# JSON_BODY_LIMIT_MB=2

# 单篇总结 / 对比的输入长度护栏（防止异常大 payload 占用内存与模型费用）
# MAX_TITLE_CHARS=500
# MAX_ABSTRACT_CHARS=50000
# MAX_FULLTEXT_CHARS=600000
# ANALYSIS_TEXT_MAX_CHARS=22000
# MAX_COMPARE_PAPERS=10
# MAX_PAPER_ABSTRACT_IN_COMPARE=12000
# RESPONSE_CACHE_TTL_MS=600000

# 速率限制（可按访问量调整；窗口内单 IP 上限）
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_HEALTH_WINDOW_MS=60000
# RATE_LIMIT_HEALTH_MAX=120
# RATE_LIMIT_PDF_MAX=25
# RATE_LIMIT_SUMMARIZE_MAX=40
# RATE_LIMIT_COMPARE_MAX=25
